# TileLang Operator Development Environment Configuration
# Copy this file to .env and update the paths according to your setup

# TileLang source repository path (required for dual-workspace mode)
# This should point to the root of your TileLang source checkout
TILELANG_SOURCE_PATH=/path/to/your/tilelang

# Optional: Custom knowledge base path (defaults to built-in if not set)
# TILELANG_KNOWLEDGE_PATH=/path/to/custom/knowledge

# Optional: Python path for TileLang (if needed)
# PYTHONPATH=$TILELANG_SOURCE_PATH:$PYTHONPATH
